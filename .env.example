# .env.example — Plantilla de variables de entorno para la aplicación.
#
# ¿Cómo usar este archivo?
# 1. Copia este archivo como .env en la raíz del proyecto:
#    cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. Docker Compose carga automáticamente el archivo .env
#
# IMPORTANTE: El archivo .env NUNCA debe subirse a Git.
# Está incluido en .gitignore. Este archivo (.env.example) SÍ se sube
# como documentación de qué variables son necesarias.
#
# ¿Por qué variables de entorno?
# Principio 12-Factor App (factor III): la configuración que varía entre
# entornos (desarrollo, staging, producción) debe estar en el entorno,
# no en el código. Esto permite desplegar el mismo artefacto en cualquier
# entorno solo cambiando las variables.

# ============================================================
# Base de datos PostgreSQL
# ============================================================

# Nombre de la base de datos a crear
POSTGRES_DB=easy_offers_db

# Usuario de PostgreSQL (no usar "postgres" en producción)
POSTGRES_USER=easy_user

# Contraseña de PostgreSQL
# En producción: usar una contraseña aleatoria de al menos 32 caracteres
# Ejemplo de generación: openssl rand -base64 32
POSTGRES_PASSWORD=easy_password

# ============================================================
# JWT (JSON Web Token)
# ============================================================

# Clave secreta para firmar los tokens JWT con algoritmo HS256.
# REQUISITOS DE SEGURIDAD:
# - Mínimo 256 bits (32 bytes) para HS256
# - Debe ser completamente aleatoria
# - NUNCA compartir ni versionar esta clave
# Ejemplo de generación: openssl rand -base64 64
JWT_SECRET=dev-secret-key-change-in-production-must-be-at-least-256-bits-long

# Vigencia del token JWT en horas (default: 8 horas según Requerimiento 1.1)
JWT_EXPIRATION_HOURS=8

# ============================================================
# Spring Boot
# ============================================================

# Perfil activo de Spring Boot
# Valores posibles: dev, prod
# - dev: usa application-dev.yml (más logs, show-sql=true)
# - prod: usa solo application.yml (logs mínimos, show-sql=false)
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# Notas de seguridad para producción
# ============================================================
# 1. Cambiar TODAS las contraseñas y claves antes de desplegar
# 2. Usar un gestor de secretos (AWS Secrets Manager, HashiCorp Vault)
#    en lugar de archivos .env en producción
# 3. Rotar JWT_SECRET periódicamente (invalida todos los tokens activos)
# 4. Usar POSTGRES_PASSWORD con al menos 32 caracteres aleatorios
